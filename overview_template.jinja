<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ site_title }}</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div class="site">
      <main class="post-grid">
        {% for post in posts %}
        <article class="post-card{% if post.first_image %} post-card--wide{% endif %}">
          <a class="post-card__link" href="posts/{{ post.slug }}.html">
            <div class="post-card__content">
              {% if post.first_image %}
              <img
                src="{{ post.first_image }}"
                alt=""
                class="post-card__image"
                loading="lazy"
              />
              {% endif %}
              <h2 class="post-card__title">{{ post.title }}</h2>
            </div>
          </a>
        </article>
        {% endfor %}
      </main>
    </div>
  </body>
</html>

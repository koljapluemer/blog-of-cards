<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ site_title }}</title>
  <link rel="stylesheet" href="styles.css" />
</head>

<body class="site">
  <main class="post-grid">
    {% for post in posts %}
    <article class="post-card{% if post.first_image %} post-card--wide{% endif %}">
      <a class="post-card__link" href="posts/{{ post.slug }}.html">
        <div class="post-card__content">
          {% if post.first_image %}
          <img src="{{ post.first_image }}" alt="" class="post-card__image" loading="lazy" />
          {% endif %}
          <h2 class="post-card__title">{{ post.title }}</h2>
        </div>
      </a>
    </article>
    {% endfor %}
  </main>
  <footer>
    <p>
      By <a href="https://koljasam.com/" target="_blank">Kolja Sam</a>. If you want to support my work, you can
      <a href="https://ko-fi.com/S6S81CWUVD" target="_blank" rel="noopener" class="kofi-btn">
        buy me a coffee
      </a>.
    </p>
  </footer>
</body>
<script>
  window.goatcounter = {
    path: function (p) { return location.host + p }
  }
</script>
<script data-goatcounter="https://koljasam.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

</html>